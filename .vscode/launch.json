{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Next.js: debug server-side",
            "type": "node-terminal",
            "request": "launch",
            "command": "pnpm dev --port 3004",
            "preLaunchTask": "Kill Port 3004",
            "serverReadyAction": {
                "pattern": "- Local:\\s+(https?://\\S+)",
                "uriFormat": "%s",
                "action": "debugWithChrome"
            }
        },
        {
            "name": "Next.js: debug client-side",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:3004"
        },
        {
            "name": "Next.js: debug full stack",
            "type": "node-terminal",
            "request": "launch",
            "command": "pnpm dev --port 3004",
            "preLaunchTask": "Kill Port 3004",
            "serverReadyAction": {
                "pattern": "- Local:\\s+(https?://\\S+)",
                "uriFormat": "%s",
                "action": "debugWithChrome"
            }
        }
    ]
}